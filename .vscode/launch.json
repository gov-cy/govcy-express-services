    "version": "0.2.0",
    "configurations": [
    
        {
            "type": "node",
            "request": "launch",
            "name": "Launch Program",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}/src/standalone.mjs",
            "env": {
                "NODE_ENV": "development",
                "DEBUG": "true"
            }
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Launch All Features Program",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}/tests/mocks/all-features/allFeaturesStarter.mjs",
            "env": {
                "NODE_ENV": "development",
                "DEBUG": "true"
            }
        }
    ]
}
